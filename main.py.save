from router import route
from actions import turn_on, turn_off
from llm import ask_llm
from logger import log
from state import set_context

print("🚀 Assistant Core Step 2 gestartet")

while True:
    text = input("Du: ")

    log("INPUT", text)

    mode = route(text)
    log("ROUTE", mode)

    set_context("last_input", text)
    set_context("last_intent", mode)

    # -------------------
    # DEVICE MODE (SMARTER)
    # -------------------
    if mode == "device":

        t = text.lower()

        if "an" in t or "ein" in t:
            turn_on("light.livingroom")
            set_context("last_action", "light_on")
            print("KI: Licht eingeschaltet")
            continue

        if "aus" in t:
            turn_off("light.livingroom")
            set_context("last_action", "light_off")
            print("KI: Licht ausgeschaltet")
            continue

        print("KI: Gerät erkannt, aber nicht sicher was zu tun ist")
        continue

    # -------------------
    # SENSOR MODE
    # -------------------
    if mode == "sensor":
        print("KI: Sensorintegration kommt in Step 3")
        continue

    # -------------------
    # SIMPLE MODE
    # -------------------
    if mode == "simple":
        print("KI: Hallo 👋")
        continue

    # -------------------
    # LLM MODE
    # -------------------
    elif mode == "knowledge":
    from knowledge import get_knowledge

    context = get_knowledge(text)

    prompt = f"""
Kontext:
{context}

Frage:
{text}
"""

    answer = ask_llm(prompt)
    print("KI:", answer)
from router import route
from actions import turn_on, turn_off
from llm import ask_llm
from logger import log
