    # DEVICE MODE (SMARTER)
    # -------------------
    if mode == "device":

        t = text.lower()

        if "an" in t or "ein" in t:
            turn_on("light.livingroom")
            set_context("last_action", "light_on")
            print("KI: Licht eingeschaltet")
            continue

        if "aus" in t:
